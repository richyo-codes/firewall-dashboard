# Example environment file for pf-dashboard systemd service.
# This file is installed to /etc/default/pf-dashboard (Debian) or
# /etc/sysconfig/pf-dashboard (RPM) by packaging.

# Optional extra CLI flags appended to ExecStart.
# Example:
# PF_DASHBOARD_FLAGS="--server.addr=0.0.0.0:8080 --server.http_log"
PF_DASHBOARD_FLAGS=""

# Core app settings can also be set via PFCTL_DASHBOARD_* environment variables.
# Example PF mode:
# PFCTL_DASHBOARD_FIREWALL_BACKEND=pf
#
# Example nftables mode:
# PFCTL_DASHBOARD_FIREWALL_BACKEND=nftables
#
# Example auth mode:
# PFCTL_DASHBOARD_AUTH_MODE=none
# PFCTL_DASHBOARD_AUTH_MODE=oidc
# PFCTL_DASHBOARD_AUTH_OIDC_PROVIDER_URL=https://id.example.com
# PFCTL_DASHBOARD_AUTH_OIDC_CLIENT_ID=pf-dashboard
# PFCTL_DASHBOARD_AUTH_OIDC_CLIENT_SECRET=replace-me
# PFCTL_DASHBOARD_AUTH_OIDC_REDIRECT_URL=https://dashboard.example.com/auth/callback

